# =================================================================
# Azure DevOps MCP Server - Configuração de Ambiente (.env)
# =================================================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo para ".env" (remove o .example)
# 2. Substitua os valores pelos seus dados reais
# 3. Nunca commite o arquivo .env (está no .gitignore)
# 4. Para usar local: carregue antes de iniciar o servidor
# 5. Para Docker: use --env-file .env
#
# =================================================================
# CREDENCIAIS OBRIGATÓRIAS
# =================================================================

# Personal Access Token (PAT) de Azure DevOps
# Obter em: https://dev.azure.com/{org}/_usersSettings/tokens
# Escopos necessários: Work Items (Full), Project & Team (Read)
AZURE_DEVOPS_PAT=seu_token_pessoal_aqui

# URL da Organização Azure DevOps
# Formato: https://dev.azure.com/{nome-organizacao}
# Exemplo: https://dev.azure.com/minha-empresa
AZURE_DEVOPS_ORG=https://dev.azure.com/sua_organizacao

# Projeto padrão em Azure DevOps
# Deve existir na organização antes de rodar o servidor
# Pode conter espaços e caracteres especiais
AZURE_DEVOPS_PROJECT=seu_projeto_padrao

# =================================================================
# CONFIGURAÇÃO DO PROTOCOLO MCP
# =================================================================

# Modo de transporte MCP:
# - http   = REST HTTP (para testes locais, desenvolvimento)
# - stdio  = stdin/stdout (para Copilot CLI, Claude Desktop)
MCP_TRANSPORT=http

# =================================================================
# AMBIENTE DA APLICAÇÃO
# =================================================================

# Environment da aplicação:
# - Development  = Logging detalhado, sem otimizações
# - Production   = Logging mínimo, otimizações ativas
ASPNETCORE_ENVIRONMENT=Development

# =================================================================
# CONFIGURAÇÃO DO SERVIDOR (MODO HTTP)
# =================================================================

# URL e porta do servidor (apenas modo HTTP)
# Padrão: http://localhost:5050
# ASPNETCORE_URLS=http://localhost:5050

# =================================================================
# EXEMPLOS DE USO
# =================================================================

# PowerShell (carregar variáveis do .env):
#   $env:AZURE_DEVOPS_PAT = "seu-token"
#   foreach ($line in (Get-Content .env)) {
#     if ($line -and -not $line.StartsWith("#")) {
#       $key, $val = $line.Split('=')
#       [Environment]::SetEnvironmentVariable($key, $val)
#     }
#   }

# Linux/macOS (bash/zsh):
#   set -a
#   source .env
#   set +a

# Docker:
#   docker build -t azure-devops-mcp-server:latest .
#   docker run --env-file .env azure-devops-mcp-server:latest

# Docker Compose:
#   docker-compose up -d
